<!DOCTYPE html>
<html lang="zh-CN" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}加班记录管理系统{% endblock %}</title>

    <!-- Google Fonts: Manrope + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">

    <!-- Material Symbols Outlined -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet">

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Custom Design System -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/tokens.css') }}?v=2">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/base.css') }}?v=2">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/components.css') }}?v=2">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/interactions.css') }}?v=2">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/responsive.css') }}?v=2">

    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            darkMode: ['class', '[data-theme="dark"]'],
            theme: {
                extend: {
                    colors: {
                        primary: {
                            DEFAULT: '#000666',
                            container: '#1a237e',
                            fixed: '#e0e0ff',
                            'fixed-dim': '#bdc2ff',
                        },
                        'on-primary': {
                            DEFAULT: '#ffffff',
                            container: '#8690ee',
                            fixed: '#000767',
                            'fixed-variant': '#343d96',
                        },
                        secondary: {
                            DEFAULT: '#1b6d24',
                            container: '#a0f399',
                        },
                        'on-secondary': {
                            DEFAULT: '#ffffff',
                            container: '#217128',
                        },
                        tertiary: {
                            DEFAULT: '#321100',
                            container: '#532100',
                        },
                        'on-tertiary': {
                            container: '#f57009',
                        },
                        error: {
                            DEFAULT: '#ba1a1a',
                            container: '#ffdad6',
                        },
                        'on-error': {
                            DEFAULT: '#ffffff',
                            container: '#93000a',
                        },
                        surface: {
                            DEFAULT: '#fbf8ff',
                            variant: '#e2e1ed',
                        },
                        'on-surface': {
                            DEFAULT: '#1a1b23',
                            variant: '#454652',
                        },
                        'surface-container': {
                            lowest: '#ffffff',
                            low: '#f3f2fe',
                            DEFAULT: '#eeedf8',
                            high: '#e8e7f2',
                            highest: '#e2e1ed',
                        },
                        outline: {
                            DEFAULT: '#767683',
                            variant: '#c6c5d4',
                        },
                    },
                    fontFamily: {
                        headline: ['Manrope', '-apple-system', 'sans-serif'],
                        body: ['Inter', '-apple-system', 'sans-serif'],
                    },
                },
            },
        };
    </script>

    {% block extra_css %}{% endblock %}
</head>
<body class="bg-surface text-on-surface font-body page-transition">

    <!-- Skip to main content (Accessibility) -->
    <a href="#main-content" class="skip-link">跳转到主要内容</a>

    <!-- Sidebar (Authority Panel) -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <h1>Lex &amp; Ledger</h1>
            <p>The Digital Jurist</p>
        </div>

        <nav class="sidebar-nav">
            <a href="{{ url_for('dashboard.index') }}"
               class="sidebar-nav-item {% if request.endpoint == 'dashboard.index' %}active{% endif %}">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a href="{{ url_for('employees.list_employees') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('employees') %}active{% endif %}">
                <span class="material-symbols-outlined">badge</span>
                <span>员工管理</span>
            </a>
            <a href="{{ url_for('records.import_records') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('records') %}active{% endif %}">
                <span class="material-symbols-outlined">upload_file</span>
                <span>记录导入</span>
            </a>
            <a href="{{ url_for('review.review_queue') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('review') %}active{% endif %}">
                <span class="material-symbols-outlined">fact_check</span>
                <span>审批队列</span>
            </a>
            <a href="{{ url_for('reports.reports_index') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('reports') %}active{% endif %}">
                <span class="material-symbols-outlined">description</span>
                <span>报表查看</span>
            </a>
            <a href="{{ url_for('holidays.list_holidays') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('holidays') %}active{% endif %}">
                <span class="material-symbols-outlined">calendar_today</span>
                <span>节假日管理</span>
            </a>
            <a href="{{ url_for('notifications.notification_center') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('notifications') %}active{% endif %}">
                <span class="material-symbols-outlined">notifications</span>
                <span>通知中心</span>
            </a>
            <a href="{{ url_for('assistant.index') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('assistant') %}active{% endif %}">
                <span class="material-symbols-outlined">smart_toy</span>
                <span>AI 助手</span>
            </a>
            <a href="{{ url_for('settings.settings_index') }}"
               class="sidebar-nav-item {% if request.endpoint and request.endpoint.startswith('settings') %}active{% endif %}">
                <span class="material-symbols-outlined">settings</span>
                <span>系统设置</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="flex items-center gap-3 text-white/50 text-xs">
                <span class="material-symbols-outlined text-base">help_center</span>
                <span>Support</span>
            </div>
        </div>
    </aside>

    <!-- Mobile Sidebar Overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

    <!-- Main Content -->
    <main class="main-content" id="main-content">
        <!-- Top App Bar -->
        <header class="top-app-bar">
            <div class="top-app-bar-leading">
                <!-- Mobile menu button -->
                <button type="button" class="top-app-bar-btn lg:hidden" onclick="toggleSidebar()" aria-label="打开菜单">
                    <span class="material-symbols-outlined">menu</span>
                </button>

                <div class="top-app-bar-title-group">
                    <h1 class="top-app-bar-title">{% block page_title %}Dashboard{% endblock %}</h1>
                    <span class="top-app-bar-subtitle">Lex & Ledger</span>
                </div>
            </div>

            <div class="top-app-bar-actions">
                <!-- Search trigger (icon-only, compact) -->
                <button type="button" class="top-app-bar-btn" aria-label="搜索" title="搜索">
                    <span class="material-symbols-outlined">search</span>
                </button>

                <!-- Notifications -->
                <a href="{{ url_for('notifications.notification_center') }}" class="top-app-bar-btn relative" aria-label="通知" title="通知">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="notification-badge" aria-hidden="true"></span>
                </a>

                <!-- Settings -->
                <a href="{{ url_for('settings.settings_index') }}" class="top-app-bar-btn" aria-label="设置" title="设置">
                    <span class="material-symbols-outlined">settings</span>
                </a>

                <!-- User Avatar -->
                <div class="user-avatar" title="管理员">
                    <span>AD</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="flex-1">
            <!-- Flash Messages -->
            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                    <div class="page-container pb-0">
                        {% for category, message in messages %}
                            <div class="alert alert-{{ 'error' if category == 'error' else category }} mb-4" role="alert">
                                <span class="material-symbols-outlined">
                                    {% if category == 'success' %}check_circle
                                    {% elif category == 'error' %}error
                                    {% elif category == 'warning' %}warning
                                    {% else %}info{% endif %}
                                </span>
                                <span>{{ message }}</span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            {% endwith %}

            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- Scripts -->
    <script>
        // Mobile sidebar toggle
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('active');
            document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
        }

        // Close sidebar on window resize (if going to desktop)
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) {
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('sidebar-overlay');
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }
        });

        // Auto-hide flash messages after 5 seconds
        document.addEventListener('DOMContentLoaded', () => {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.opacity = '0';
                    alert.style.transition = 'opacity 0.3s ease';
                    setTimeout(() => alert.remove(), 300);
                }, 5000);
            });
        });
    </script>

    <!-- Toast Container -->
    {% from "components/toast.html" import toast_container with context %}
    {{ toast_container() }}

    <!-- Component Scripts -->
    <script src="{{ url_for('static', filename='js/components.js') }}"></script>
    <script src="{{ url_for('static', filename='js/interactions.js') }}"></script>

    {% block extra_js %}{% endblock %}
</body>
</html>
